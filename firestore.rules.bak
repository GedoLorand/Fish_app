rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Top-level images collection
    match /images/{imageId} {
      allow read: if resource.data.public == true || (request.auth != null && request.auth.uid == resource.data.ownerId);
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.ownerId;
    }

    // collectionGroup rule for images in arbitrary paths
    match /{path=**}/images/{imageId} {
      allow read: if resource.data.public == true || (request.auth != null && request.auth.uid == resource.data.ownerId);
    }

    // user-specific images
    match /users/{userId}/images/{imageId} {
      allow read: if resource.data.public == true || (request.auth != null && request.auth.uid == userId);
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // reports
    match /reports/{reportId} {
      allow create: if request.auth != null
                    && request.resource.data.reason is string
                    && request.resource.data.reason.size() <= 200;
      allow read, delete: if request.auth != null && request.auth.token.admin == true;
    }

    // private messages
    match /private_messages/{messageId} {
      allow create: if request.auth != null
                    && request.resource.data.senderUid == request.auth.uid
                    && request.resource.data.participants is list
                    && request.resource.data.participants.size() == 2
                    && request.resource.data.participants.contains(request.auth.uid);

      allow read: if request.auth != null
                  && resource.data.participants is list
                  && resource.data.participants.contains(request.auth.uid);

      allow update, delete: if false;
    }

    // users
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Reports collection: anyone authenticated can create; only admin can read/delete
    match /reports/{reportId} {
      allow create: if request.auth != null
        && request.resource.data.reason is string
        && request.resource.data.reason.size() <= 200;

      // Admin check by custom claim or by email
      allow read, delete: if request.auth != null && (
        request.auth.token.admin == true ||
        request.auth.token.email == "gedolorand@gmail.com"
      );
    }

    // Top-level images collection: only admins can delete documents
    match /images/{imageDoc} {
      allow read: if request.auth != null && request.auth.uid != null; // basic read for authenticated users
      allow create: if request.auth != null; // app may write images
      allow delete: if request.auth != null && (
        request.auth.token.admin == true ||
        request.auth.token.email == "gedolorand@gmail.com"
      );
    }

    // Per-user images under users/{uid}/images/{imageId}
    match /users/{userId}/images/{imageId} {
      allow read: if request.auth != null && (request.auth.uid == userId || request.auth.token.admin == true || request.auth.token.email == "gedolorand@gmail.com");
      allow create: if request.auth != null && request.auth.uid == userId; // users can create their own image docs
      allow delete: if request.auth != null && (
        request.auth.token.admin == true ||
        request.auth.token.email == "gedolorand@gmail.com" ||
        request.auth.uid == userId
      );
    }

    // Fallback: other collections keep default deny (or add project-specific rules)
  }
}
