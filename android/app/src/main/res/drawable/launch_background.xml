<?xml version="1.0" encoding="utf-8"?>
<!-- Launch splash: solid blue background with centered app icon -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Solid app-accent background (orange) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFF26522" />
        </shape>
    </item>

    <!-- Centered app icon (ensure ic_launcher exists in mipmap-*/ folders) -->
    <item>
        <bitmap
            android:gravity="center"
            android:src="@mipmap/ic_launcher" />
    </item>
</layer-list>
