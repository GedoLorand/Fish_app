<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Simplified LaunchTheme for API 31+ that falls back to windowBackground drawable
         Avoid using android:windowSplashScreen* attributes if compileSdk/version doesn't support them -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>
</resources>
 