rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Top-level images (gallery)
    match /images/{imageId} {
      // Allow reading images if they are public or the requester is authenticated.
      // This permits MapScreen to load image docs for users who participated
      // in message threads without requiring the image to be public.
      allow read: if resource.data.public == true
                  || request.auth != null
                  || (request.auth != null && request.auth.uid == resource.data.ownerId);
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.ownerId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.ownerId;
    }

    // Allow collectionGroup reads for any nested images collection (e.g. /users/{uid}/images)
    match /{path=**}/images/{imageId} {
      // Same as top-level images: allow reads for public images or authenticated users.
      allow read: if resource.data.public == true
                  || request.auth != null
                  || (request.auth != null && request.auth.uid == resource.data.ownerId);
    }

    // Per-user profile docs
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Per-user images (under /users/{uid}/images)
    match /users/{userId}/images/{imageId} {
      allow read: if resource.data.public == true || (request.auth != null && request.auth.uid == userId);
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Per-image public messages
    match /images/{imageId}/messages/{messageId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.senderUid == request.auth.uid
                    && request.resource.data.text is string
                    && request.resource.data.text.size() <= 2000;
      allow update, delete: if false;
    }

    // Allow collectionGroup reads and writes for any nested `messages` subcollection
    // (covers /images/{id}/messages and /users/{uid}/images/{id}/messages)
    match /{path=**}/messages/{messageId} {
      // allow anyone to read public message threads
      allow read: if true;

      // allow authenticated users to create a message where senderUid==auth.uid
      // and ensure participants is a list that includes the sender
      allow create: if request.auth != null
                    && request.resource.data.senderUid == request.auth.uid
                    && request.resource.data.text is string
                    && request.resource.data.text.size() <= 2000
                    && (request.resource.data.participants is list
                        ? request.auth.uid in request.resource.data.participants
                        : true);

      allow update, delete: if false;
    }

    // Reports
    rules_version = '2';

    service cloud.firestore {
      match /databases/{database}/documents {

        // Helper functions
        function isSignedIn() { return request.auth != null; }
        function isOwner(ownerId) { return isSignedIn() && request.auth.uid == ownerId; }
        function validString(f, maxLen) { return f is string && f.size() <= maxLen; }

        // Top-level images (gallery)
        match /images/{imageId} {
          allow read: if resource.data.public == true
                      || isSignedIn();

          allow create: if isSignedIn()
                        && request.auth.uid == request.resource.data.ownerId
                        && (request.resource.data.ownerId is string)
                        && (request.resource.data.public is bool || !('public' in request.resource.data));

          allow update, delete: if isSignedIn() && request.auth.uid == resource.data.ownerId;
        }

        // Allow collectionGroup reads for any nested images collection (e.g. /users/{uid}/images)
        match /{path=**}/images/{imageId} {
          allow read: if resource.data.public == true
                      || isSignedIn();
        }

        // User profile docs
        match /users/{userId} {
          allow read: if isSignedIn();
          allow write: if isSignedIn() && request.auth.uid == userId;
        }

        // Per-user images (under /users/{uid}/images)
        match /users/{userId}/images/{imageId} {
          allow read: if resource.data.public == true || (isSignedIn() && request.auth.uid == userId);
          allow create: if isSignedIn() && request.auth.uid == userId
                        && (request.resource.data.ownerId == userId || !( 'ownerId' in request.resource.data ));
          allow update, delete: if isSignedIn() && request.auth.uid == userId;
        }

        // Messages in any messages subcollection (recursive) — needed for collectionGroup('messages')
        match /{path=**}/messages/{messageId} {
          // Message threads are public read for now (per-app design).
          allow read: if true;

          // Only signed-in users can create messages;
          // - senderUid must match auth.uid
          // - text must be a string (<=2000 chars)
          // - participants must be a list and include the sender (so array-contains queries work)
          // - createdAt should be a timestamp (client may use serverTimestamp)
          allow create: if isSignedIn()
                        && request.resource.data.senderUid == request.auth.uid
                        && request.resource.data.text is string
                        && request.resource.data.text.size() <= 2000
                        && request.resource.data.participants is list
                        && request.auth.uid in request.resource.data.participants
                        && (request.resource.data.createdAt is timestamp || !('createdAt' in request.resource.data));

          // No updates/deletes from clients
          allow update, delete: if false;
        }

        // Reports
        match /reports/{reportId} {
          allow create: if isSignedIn()
                        && validString(request.resource.data.reason, 200);
          allow read, delete: if isSignedIn() && request.auth.token.admin == true;
        }

        // Private messages (optional)
        match /private_messages/{messageId} {
          allow create: if isSignedIn()
                        && request.resource.data.senderUid == request.auth.uid
                        && request.resource.data.participants is list
                        && request.resource.data.participants.size() == 2
                        && request.auth.uid in request.resource.data.participants;

          allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
          allow update, delete: if false;
        }

      }
    }
