rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Top-level images (gallery)
    match /images/{imageId} {
      allow read: if resource.data.public == true
                  || (request.auth != null && request.auth.uid == resource.data.ownerId);
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.ownerId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.ownerId;
    }

    // Allow collectionGroup reads for any nested images collection (e.g. /users/{uid}/images)
    match /{path=**}/images/{imageId} {
      allow read: if resource.data.public == true
                  || (request.auth != null && request.auth.uid == resource.data.ownerId);
    }

    // Per-user profile docs
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Per-user images (under /users/{uid}/images)
    match /users/{userId}/images/{imageId} {
      allow read: if resource.data.public == true || (request.auth != null && request.auth.uid == userId);
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Per-image public messages
    match /images/{imageId}/messages/{messageId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.senderUid == request.auth.uid
                    && request.resource.data.text is string
                    && request.resource.data.text.size() <= 2000;
      allow update, delete: if false;
    }

    // Reports
    match /reports/{reportId} {
      allow create: if request.auth != null
                    && request.resource.data.reason is string
                    && request.resource.data.reason.size() <= 200;
      allow read, delete: if request.auth != null && request.auth.token.admin == true;
    }

    // Private messages (if you keep them)
    match /private_messages/{messageId} {
      allow create: if request.auth != null
                    && request.resource.data.senderUid == request.auth.uid
                    && request.resource.data.participants is list
                    && request.resource.data.participants.size() == 2
                    && request.auth.uid in request.resource.data.participants;
      allow read: if request.auth != null && request.auth.uid in resource.data.participants;
      allow update, delete: if false;
    }

  }
}
